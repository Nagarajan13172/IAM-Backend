# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DB=iam_db

# Full connection string (auto-built by docker-compose, override if needed)
# MONGO_URI=mongodb://admin:changeme@mongo:27017/iam_db?authSource=admin

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
